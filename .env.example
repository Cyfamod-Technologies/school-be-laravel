APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
AUTH_AGENT_PASSWORD_RESET_TOKEN_TABLE=password_reset_tokens

FRONTEND_LOGIN_URL=http://localhost:3000/login
FRONTEND_AGENT_LOGIN_URL=http://localhost:3000/agent/login
AGENT_MAX_REFERRAL_CODES=10

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=school
DB_USERNAME=root
DB_PASSWORD=1ncrease

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Toggle AWS S3 storage ("on" forces S3 for uploads, anything else keeps local disk)
S3=off
EMAIL_VERIFICATION=off
ENFORCE_ENDPOINT_PERMISSIONS=off
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_BASE_URL=https://api.paystack.co
# Total request timeout (seconds) for Paystack API calls.
PAYSTACK_TIMEOUT=30
# Connection timeout (seconds) to establish TLS connection to Paystack.
PAYSTACK_CONNECT_TIMEOUT=15
# Number of retry attempts for transient connection failures.
PAYSTACK_RETRY_TIMES=2
# Delay in milliseconds between retry attempts.
PAYSTACK_RETRY_SLEEP_MS=400

PRICE_PER_STUDENT=500
INVOICE_GENERATION_DAYS_BEFORE=14
# Enable/disable free trial globally. If false, no school gets trial.
SUBSCRIPTION_FREE_TRIAL_ENABLED=false
# Number of starting terms covered by trial (e.g. 1 = first term only).
SUBSCRIPTION_FREE_TRIAL_TERMS=1
# If true, each school can toggle trial via `enable_free_trial`.
# If false, all schools follow the global setting automatically.
SUBSCRIPTION_FREE_TRIAL_OPTIONAL_PER_SCHOOL=true
# Default value for new schools when optional-per-school mode is enabled.
SUBSCRIPTION_FREE_TRIAL_DEFAULT_FOR_NEW_SCHOOL=false

VITE_APP_NAME="${APP_NAME}"


L5_SWAGGER_BASE_PATH=http://127.0.0.1:8000/api
L5_SWAGGER_CONST_HOST=http://127.0.0.1:8000/api
L5_SWAGGER_GENERATE_ALWAYS=true
L5_SWAGGER_UI_DARK_MODE=false
